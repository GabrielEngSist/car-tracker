{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Car.Tracker (full stack)",
      "configurations": ["Car.Tracker.Api", "ClientApp (Chrome)"]
    }
  ],
  "configurations": [
    {
      "name": "Car.Tracker.Api",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/Car.Tracker.Api/bin/Debug/net10.0/Car.Tracker.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/Car.Tracker.Api",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "launchSettingsFilePath": "${workspaceFolder}/src/Car.Tracker.Api/Properties/launchSettings.json",
      "launchSettingsProfileName": "http"
    },
    {
      "name": "ClientApp (Chrome)",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "frontend:dev",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/Car.Tracker.Presentation/src"
    },
    {
      "name": "Car.Tracker.Api (attach)",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
